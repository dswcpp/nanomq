################################################################################
# NanoMQ .gitignore
#
# Ignores build artifacts, dependencies, editor files, and development artifacts
# to keep the repository clean and focused on source code.
################################################################################

# ============================================================================
# Compiled Objects & Executables
# ============================================================================

# C/C++ Object files
*.o
*.ko
*.obj
*.elf

# Precompiled Headers
*.gch
*.pch

# Static/Shared Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables and binaries
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug symbols
*.dSYM/
*.su

# ============================================================================
# Build & CMake Artifacts
# ============================================================================

# Default CMake build directories (all variants)
build/
build-cmake-*/
build-deb/
build-deb-taos/
build-deb-notests/
build-deb-debug/
build-tests/
build-runtime/
build-check-fix/
cmake-build-debug/
cmake-build-release/

# CPack generated files (for .deb/.rpm/.zip packaging)
_CPack_Packages/
*.deb
*.deb.sig

# CMake generated files
CMakeFiles/
cmake_install.cmake
CMakeCache.txt
CPackConfig.cmake
CPackSourceConfig.cmake
Makefile

# Compiled binaries from builds
nanomq-nng-*.deb
nanomq-*.deb

# Release archives and checksums generated under public/
public/*.zip
public/*.tar.gz
public/*/*.deb.sha256

# ============================================================================
# Dependencies & Submodules
# ============================================================================

# Local dependency worktrees / clones (managed by /scripts or manual setup)
NanoNNG/
extern/l8w8jwt/

# ============================================================================
# Generated/Transient Files
# ============================================================================

# Generated header files
fdb_version.h

# Runtime test artifacts
tmp/
test_taos.sh
test_taos_sink.sh

# ============================================================================
# Windows Cross-Compilation Artifacts
# ============================================================================
# DLL leftovers when cross-compiling for Windows (can appear in project root)
libatomic-1.dll
libwinpthread-1.dll

# ============================================================================
# IDE & Editor
# ============================================================================

# JetBrains IDEs (IntelliJ, CLion, PhpStorm, etc.)
.idea/

# Visual Studio Code
.vscode/
*.code-workspace

# VS Code settings (user-specific)
.vscode/settings.json
.vscode/launch.json

# Claude Code local context
.claude/

# Vim/Neovim temporary files
*.swp
*.swo
*~
.vim/
.netrwhist

# ============================================================================
# OS-Specific Files
# ============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
*.DS_Store

# Windows
Thumbs.db
desktop.ini
*.lnk

# Linux
.directory
.Trash-*
